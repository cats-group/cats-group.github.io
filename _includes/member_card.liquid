<div class="col">
  <div class="card h-100 border-0 shadow-sm member-card">
    <img
      src="{{ '/assets/img/' | append: include.person.image | relative_url }}"
      class="card-img-top member-card-image"
      alt="{{ include.person.name }}"
    >
    <div class="card-body">
      <h4 class="card-title mb-1 member-card-name">{{ include.person.name }}</h4>
      <p class="text-muted mb-2">{{ include.person.role }}</p>
      <p class="card-text">{{ include.person.bio }}</p>
      <p class="mb-0 member-social-links d-flex flex-wrap align-items-center">
        {% if include.person.website %}
          <a href="{{ include.person.website }}" target="_blank" rel="noopener" title="Website" aria-label="Website">
            <i class="fa-solid fa-globe"></i>
          </a>
        {% endif %}
        {% if include.person.twitter %}
          <a href="{{ include.person.twitter }}" target="_blank" rel="noopener" title="Twitter" aria-label="Twitter">
            <i class="fa-brands fa-x-twitter"></i>
          </a>
        {% endif %}
        {% if include.person.bluesky %}
          <a href="{{ include.person.bluesky }}" target="_blank" rel="noopener" title="Bluesky" aria-label="Bluesky">
            <i class="fa-brands fa-bluesky"></i>
          </a>
        {% endif %}
        {% if include.person.linkedin %}
          <a href="{{ include.person.linkedin }}" target="_blank" rel="noopener" title="LinkedIn" aria-label="LinkedIn">
            <i class="fa-brands fa-linkedin"></i>
          </a>
        {% endif %}
      </p>
    </div>
  </div>
</div>
